# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.python-version
.venv/
venv/

# --- Generated simulation data ---
# Re-generated by scripts/run_*.py — large and lossless to skip.
results/data/*.csv

# Keep the PNG figures committed so the static site has plots without
# requiring users to install Python locally.
!results/figures/
results/figures/*.csv

# --- Node / Vite ---
web/node_modules/
web/dist/
# web/public/figures is a derived mirror of results/figures (predev hook).
web/public/figures/

# --- Editor / OS ---
.DS_Store
.vscode/
.idea/
*.swp

# --- Paper PDF (IEEE copyrighted; do not check in) ---
paper/*.pdf

# --- Claude Code per-machine settings ---
.claude/
.github/workflows/
